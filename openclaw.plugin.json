{
  "$schema": "https://json.schemastore.org/openclaw.plugin.json",
  "id": "habit-coach",
  "name": "Habit Coach",
  "description": "AI accountability coach \u2014 dynamic task scheduling, progress tracking, streaks, and reward/penalty system for OpenClaw agents",
  "version": "0.1.1",
  "contracts": {
    "tools": [
      "habit_tasks",
      "habit_checkin",
      "habit_progress",
      "habit_report",
      "habit_set_goal",
      "habit_get_state"
    ]
  },
  "hooks": {
    "gateway_start": true
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "stateFile": {
        "type": "string",
        "description": "Path to the habit state JSON file"
      },
      "user": {
        "type": "string",
        "description": "User identifier"
      },
      "deliveryChannels": {
        "type": "array",
        "description": "Ordered list of delivery channels (first = primary, rest = fallback)",
        "items": {
          "type": "object",
          "properties": {
            "channel": {
              "type": "string",
              "description": "Channel name (e.g. openclaw-weixin, discord, telegram)"
            },
            "to": {
              "type": "string",
              "description": "Channel-specific target (user ID, chat ID, etc.)"
            },
            "accountId": {
              "type": "string",
              "description": "Optional account ID for multi-account channels"
            }
          },
          "required": [
            "channel",
            "to"
          ]
        },
        "default": [
          {
            "channel": "discord",
            "to": "user:YOUR_DISCORD_USER_ID"
          }
        ]
      },
      "reviewTime": {
        "type": "string",
        "description": "Time for daily review/check-in (HH:MM format, 24h)",
        "default": "23:00"
      },
      "allowAgentMessages": {
        "type": "boolean",
        "description": "Allow outbound delivery via agent message tool",
        "default": true
      },
      "checkinTime": {
        "type": "string",
        "description": "Time for daily task delivery (HH:MM format, 24h)",
        "default": "07:00"
      }
    },
    "required": [
      "stateFile",
      "user",
      "deliveryChannels",
      "checkinTime"
    ]
  },
  "skills": [
    "skills/habit-coach/SKILL.md"
  ]
}