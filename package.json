{
  "name": "openclaw-habit-coach",
  "version": "0.1.2",
  "description": "AI accountability coach plugin for OpenClaw — dynamic task scheduling, progress tracking, and reward/penalty system",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucianFord/openclaw-habit-coach.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "demo": "npm run build && node scripts/demo.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["openclaw", "plugin", "habit", "accountability", "coach", "task", "cron"],
  "license": "MIT",
  "files": [
    "dist",
    "examples",
    "skills",
    "openclaw.plugin.json"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.6.6"
    }
  }
}
